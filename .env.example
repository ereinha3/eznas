# Development environment variables
# Copy to .env and customize for your setup

# User/Group IDs (should match your host user)
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# Paths - relative paths work out of the box for development
# For production, use absolute paths to your NAS storage
POOL_PATH=./test_pool
SCRATCH_PATH=./test_scratch
APPDATA_PATH=./test_appdata

# Pipeline worker polling interval (seconds)
PIPELINE_INTERVAL=60
